# 运行环境标识，通常用于区分 dev / prod 等环境
APP_ENV=dev

# 数据库连接串；默认使用仓库内 data 目录下的 SQLite 文件
DATABASE_URL=sqlite:///./data/app.db

# GitHub API Token，用于搜索仓库、获取 README / Releases / Commits 等数据
GITHUB_TOKEN=

# 飞书应用的 App ID
FEISHU_APP_ID=

# 飞书应用的 App Secret
FEISHU_APP_SECRET=

# 默认定时广播的飞书群 chat_id 列表，逗号分隔；配置后会按该列表逐群推送
FEISHU_CHAT_IDS=

# `/h` 帮助里“关于我介绍”的文档链接；留空则不展示该入口
FEISHU_ABOUT_DOC_URL=

# 飞书文档写入的目标文件夹 token；留空则写到应用默认可写位置
FEISHU_DOC_FOLDER_TOKEN=

# 是否启用飞书长连接收消息；true 表示走官方 SDK 长连接
FEISHU_LONG_CONNECTION_ENABLED=true

# 群聊是否要求真实 @ 机器人后才处理命令；私聊不受影响。设为 false 时仅放开群聊 slash 命令直输，非 slash 文本仍建议真实 @ 机器人
FEISHU_GROUP_REQUIRE_BOT_MENTION=true

# 飞书事件加密 key；使用加密回调时需要配置
FEISHU_EVENT_ENCRYPT_KEY=

# 飞书事件验证 token；使用事件订阅校验时需要配置
FEISHU_EVENT_VERIFICATION_TOKEN=

# 详情研究使用的 provider；当前支持 dashscope / openai
RESEARCH_PROVIDER=dashscope

# OpenAI API Key；当 RESEARCH_PROVIDER=openai 时必填
OPENAI_API_KEY=

# OpenAI 兼容代理的 Base URL；留空则使用官方默认地址
OPENAI_BASE_URL=

# OpenAI 研究模型名称
OPENAI_MODEL=gpt-5

# OpenAI 推理强度；常见值 low / medium / high
OPENAI_REASONING_EFFORT=medium

# DashScope API Key；当 RESEARCH_PROVIDER=dashscope 时必填
DASHSCOPE_API_KEY=

# DashScope 研究阶段使用的模型，负责联网深度调研
DASHSCOPE_MODEL=qwen-deep-research

# DashScope 结构化阶段使用的模型，负责把研究结果整理成 JSON
DASHSCOPE_STRUCTURER_MODEL=qwen-plus

# DashScope API Base URL；默认是阿里百炼公开地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# DashScope 研究报告阶段超时时间，单位秒
DASHSCOPE_RESEARCH_TIMEOUT_SECONDS=600

# DashScope 结构化阶段超时时间，单位秒
DASHSCOPE_STRUCTURER_TIMEOUT_SECONDS=600

# DashScope 研究报告阶段遇到可恢复网络错误时的最大重试次数
DASHSCOPE_RESEARCH_MAX_RETRIES=2

# DashScope 研究报告阶段的重试退避基数，单位秒；默认会形成 1s、2s 这样的间隔
DASHSCOPE_RESEARCH_RETRY_BACKOFF_SECONDS=1

# 注入到研究提示词中的 README 摘要最大字符数
RESEARCH_README_CHAR_LIMIT=4000

# 注入到研究提示词中的最近 Release 条数上限
RESEARCH_RELEASE_LIMIT=3

# 注入到研究提示词中的最近 Commit 条数上限
RESEARCH_COMMIT_LIMIT=5

# 调度器时区（IANA Time Zone），默认按该时区解释 cron
SCHEDULER_TIMEZONE=Asia/Shanghai

# 定时日报任务的 cron 表达式（日报唯一配置）
DAILY_DIGEST_CRON=30 9 * * 1-5

# 定时周榜任务的 cron 表达式
WEEKLY_DIGEST_CRON=30 9 * * 1

# 日榜缓存 TTL，单位秒
DAILY_DIGEST_CACHE_TTL_SECONDS=7200

# 周榜缓存 TTL，单位秒
WEEKLY_DIGEST_CACHE_TTL_SECONDS=86400

# 项目详情缓存 TTL，单位秒；超过后会重新研究并刷新文档
DETAIL_CACHE_TTL_SECONDS=86400

# 日榜 / 周榜默认展示的仓库数量
DIGEST_TOP_K=10

# 生成榜单后预生成详情页的仓库数量
PREGEN_TOP_N=5

# 榜单筛选时优先关注的话题标签，逗号分隔
TOPIC_INCLUDE=ai,llm,agents,devtools,infra,devops,frontend,fullstack

# 榜单筛选时排除的话题标签，逗号分隔
TOPIC_EXCLUDE=template,boilerplate,awesome-list
